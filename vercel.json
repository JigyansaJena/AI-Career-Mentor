{
  "version": 2,
  "builds": [
    {
      "src": "career-mentor-server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "career-mentor-UI/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "career-mentor-server/index.js"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "career-mentor-UI/dist/assets/$1"
    },
    {
      "src": "^/(.*\\.(js|css|ico|png|jpg|svg|json))",
      "dest": "career-mentor-UI/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "career-mentor-UI/dist/index.html"
    }
  ]
}